---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="font-mono">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={"I'm a web developer"} />
    <meta name="og:description" content={"I'm a web developer"} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "JetBrainsMono";
    src: url("@/static/fonts/jetbrains/var-jetbrainsmono.ttf");
    font-weight: 100 800;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "JetBrainsMono";
    src: url("@/static/fonts/jetbrains/var-jetbrainsmono-italic.ttf");
    font-weight: 100 800;
    font-style: italic;
    font-display: swap;
  }
</style>
