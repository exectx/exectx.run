---
interface Props {
  title: string;
}

const { title } = Astro.props;
import PostHog from "@/components/posthog.astro";
import ThemeLoader from "@/components/theme-loader.astro";
---

<!doctype html>
<html id="_top" lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://cdn.exectx.run" />
    <link rel="preconnect" href="https://data.exectx.run" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={"I'm a software engineer"} />
    <meta name="og:description" content={"I'm a software engineer"} />

    <title>{title}</title>
    {import.meta.env.PROD && <PostHog />}
    <ThemeLoader />
  </head>
  <body class="relative h-full min-h-screen overflow-x-hidden">
    <slot />
    <div id="noise-mask"></div>
  </body>
</html>

<style is:global>
  body {
    background-color: #fafaf7;
    color: #545454;
  }
  :root {
    color-scheme: light;
  }
  .dark body {
    background-color: #1a1a1a;
    color: #e0e0e0;
  }
  * {
    min-width: 0;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    @apply transition-colors;
    /* scrollbar-color: rgb(var(--color) / 0.5) rgb(var(--color) / 0.1); */
  }

  #noise-mask {
    position: fixed;
    inset: 0;
    top: -50%;
    left: -50%;
    right: -50%;
    bottom: -50%;
    width: 200%;
    height: 200vh;
    pointer-events: none;
    background-image: url("https://cdn.exectx.run/noise.png");
    background-size: 180px;
    background-repeat: repeat;
    opacity: 0.065;
    z-index: 9999;
    animation: noise-animation 0.2s infinite linear;
  }

  @keyframes noise-animation {
    0% {
      transform: translate(0, 0);
    }
    10% {
      transform: translate(-5%, -5%);
    }
    20% {
      transform: translate(-10%, 5%);
    }
    30% {
      transform: translate(5%, -10%);
    }
    40% {
      transform: translate(-5%, 15%);
    }
    50% {
      transform: translate(-10%, 5%);
    }
    60% {
      transform: translate(15%, 0);
    }
    70% {
      transform: translate(0, 10%);
    }
    80% {
      transform: translate(-15%, 0);
    }
    90% {
      transform: translate(10%, 5%);
    }
    100% {
      transform: translate(5%, 0);
    }
  }
</style>
